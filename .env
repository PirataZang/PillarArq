# Variáveis do projeto
PROJECT_NAME=pillararq_default

# Ambiente do AdonisJS
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=super-secret-key-that-needs-to-be-long-enough-default

# Banco de dados (Postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_DATABASE=adonis_db
# Porta exposta para a sua máquina host (para acessar o BD por fora do docker)
DB_PORT_EXTERNAL=5435

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# Porta exposta para o redis
REDIS_PORT_EXTERNAL=6381

# Frontend Port
FRONTEND_PORT=5174
